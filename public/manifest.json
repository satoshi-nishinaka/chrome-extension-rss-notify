{
  "name": "RSS Notify",
  "version": "0.0.1",
  "manifest_version": 3,
  "background": {
    "service_worker": "js/service-worker.js"
  },
  "permissions": [
  ],
  "action": {
    "default_title": "",
    "default_icon": "icons/128.png",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [ "http://*/*", "https://*/*" ],
      "js": [
        "js/content_script.js"
      ],
      "run_at":"document_start",
      "css": []
    }
  ],
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}